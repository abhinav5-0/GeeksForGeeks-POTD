class Solution {
public:
    string findLargest(vector<int> &arr) {
        vector<string> nums;
        
        // Convert integers to strings
        for (int num : arr) {
            nums.push_back(to_string(num));
        }
        
        // Custom sort
        sort(nums.begin(), nums.end(), [](string &a, string &b) {
            return a + b > b + a;
        });
        
        // Edge case: if largest is "0"
        if (nums[0] == "0")
            return "0";
        
        // Concatenate result
        string result = "";
        for (string s : nums) {
            result += s;
        }
        
        return result;
    }
};
